# Supabase project URL from Project Settings > API
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Supabase anon/public key from Project Settings > API
VITE_SUPABASE_ANON_KEY=your-anon-key

# Optional: storage bucket used for chord sheet uploads
VITE_SUPABASE_SONG_BUCKET=song-pdfs

# Optional: max upload size in MB (client-side validation)
VITE_MAX_PDF_MB=15
